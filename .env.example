# HTTP 서버 바인딩 주소
SERVER_ADDR=0.0.0.0:8081

# Redis — 중복 체크 키 저장소
REDIS_URL=redis://127.0.0.1:6379

# RabbitMQ — AMQP 0-9-1 프로토콜
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/%2F

# MySQL — 트랜잭션 원본 이벤트 저장
MYSQL_URL=mysql://user:password@127.0.0.1:3306/events_db

# PostgreSQL — 분석 데이터 저장
POSTGRES_URL=postgres://user:password@127.0.0.1:5432/analytics_db

# Redis dedup TTL (초) — 이 시간 안에 같은 id가 오면 중복 처리
# 300 = 5분, 이벤트 재전송 타임아웃보다 크게 설정해야 함
DEDUP_TTL_SECS=300

# RabbitMQ 설정 (기본값 그대로 사용해도 됨)
EXCHANGE_NAME=events
MYSQL_QUEUE=queue.transactions
POSTGRES_QUEUE=queue.analytics

# 로그 레벨 (trace < debug < info < warn < error)
# 운영: info, 개발: debug
RUST_LOG=realtime_ingestion=info

# 텔레그램 알림 (미설정 시 알림 비활성화)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# MySQL 배치 INSERT 설정
MYSQL_BATCH_SIZE=100
MYSQL_BATCH_INTERVAL=1

# PostgreSQL 배치 INSERT 설정
PGSQL_BATCH_SIZE=100
PGSQL_BATCH_INTERVAL=1

# TCP 리스너 — 카드 단말기 전문 수신
TCP_ADDR=0.0.0.0:38701
# 허용 IP 목록 (쉼표 구분). 비워두면 모든 IP 허용.
ALLOWED_IPS=

# ── 보안 설정 ───────────────────────────────────────────────────────────────

# HTTP API 키 (X-API-Key 헤더). 비워두면 인증 비활성화.
API_KEY=

# HTTP Rate Limiting (IP당)
HTTP_RATE_PER_SECOND=100
HTTP_RATE_BURST=200

# HTTP 요청 바디 최대 크기 (바이트). 기본 65536 = 64KB.
HTTP_MAX_BODY_BYTES=65536

# TCP 최대 동시 연결 수
TCP_MAX_CONNECTIONS=1000
# IP당 최대 동시 TCP 연결 수
TCP_MAX_CONN_PER_IP=10
# TCP 프레임 최대 크기 (바이트). 기본 8192 = 8KB.
TCP_MAX_FRAME_BYTES=8192
